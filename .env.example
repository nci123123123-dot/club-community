# Data backend: "mock" (default, localStorage — no setup needed) or "supabase"
NEXT_PUBLIC_DATA_SOURCE=mock

# Supabase (only needed when NEXT_PUBLIC_DATA_SOURCE=supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auto-translation provider.
# By default (no key) posts are translated via the free, no-signup MyMemory API
# through /api/translate. Set OPENAI_API_KEY to upgrade quality automatically.
# (DeepL is intentionally not used here because it has no Vietnamese support.)
# OPENAI_API_KEY=
